---
import Img from './Img.astro';

const titleWords = 'Privirea ta, în cea mai bună formă.'.split(' ');
const accentFrom = 5; // "bună formă." rendered as italic accent
---
<section class="hero">
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="hero__inner">
    <div class="hero__copy">
      <p class="hero__eyebrow" data-reveal>
        <span class="hero__dot" aria-hidden="true"></span>
        Studio de înfrumusețare · Brașov
      </p>

      <h1 class="h1 hero__title">
        {titleWords.map((word, i) => (
          <Fragment>
            <span
              class:list={['hero__word', i >= accentFrom && 'hero__word--accent']}
              data-reveal
              style={`transition-delay:${(0.05 + i * 0.06).toFixed(2)}s`}
            >{word}</span>{' '}
          </Fragment>
        ))}
      </h1>

      <p class="lead hero__sub" data-reveal data-reveal-delay="2">
        Extensii de gene, stilizare sprâncene și îngrijirea tenului — într-un
        spațiu intim, cu tehnicieni certificați.
      </p>

      <div class="hero__cta" data-reveal data-reveal-delay="3">
        <a href="#contact" class="btn btn--primary">Rezervă o programare</a>
        <a href="#servicii" class="btn btn--ghost">Vezi serviciile</a>
      </div>

      <ul class="hero__trust" data-reveal data-reveal-delay="3">
        <li><strong>★ 4.9</strong><span>din 200+ recenzii</span></li>
        <li><strong>1.200+</strong><span>cliente mulțumite</span></li>
        <li><strong>6 ani</strong><span>experiență</span></li>
      </ul>
    </div>
  </div>

  <div class="hero__photo">
    <Img
      name="hero"
      ratio="4 / 5"
      alt="Privire de aproape cu extensii de gene lungi, naturale, în tonuri calde"
      eager
      sizes="(min-width: 860px) 62vw, 100vw"
      widths={[600, 900, 1200]}
      class="hero__img"
    />
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    display: flex;
    flex-direction: column;
  }

  /* Layered warm background */
  .hero__bg {
    position: absolute; inset: 0; z-index: -2;
    background:
      radial-gradient(70% 55% at 85% 15%, color-mix(in oklab, var(--blush) 70%, transparent), transparent 60%),
      radial-gradient(60% 60% at 10% 6%, color-mix(in oklab, var(--gold) 20%, transparent), transparent 55%),
      radial-gradient(90% 90% at 50% 120%, color-mix(in oklab, var(--blush) 40%, transparent), transparent 60%),
      var(--cream);
  }

  .hero__inner {
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 1rem;
  }
  .hero__copy { max-width: 34rem; }

  .hero__eyebrow {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--plum); font-weight: 600;
    background: color-mix(in oklab, var(--cream) 55%, white);
    border: 1px solid color-mix(in oklab, var(--gold) 40%, transparent);
    padding: 0.4rem 0.85rem; border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .hero__dot {
    width: 0.45rem; height: 0.45rem; border-radius: 999px;
    background: var(--gold); box-shadow: 0 0 0 3px color-mix(in oklab, var(--gold) 25%, transparent);
  }

  .hero__title { color: var(--plum); }
  .hero__word { display: inline-block; }
  .hero__word--accent { font-style: italic; color: color-mix(in oklab, var(--gold) 62%, var(--plum)); }

  .hero__sub {
    margin-top: 1.4rem; max-width: 34ch;
    color: color-mix(in oklab, var(--ink) 82%, transparent);
  }

  .hero__cta { margin-top: 2rem; display: flex; flex-wrap: wrap; gap: 0.75rem; }

  .hero__trust {
    list-style: none; display: flex; flex-wrap: wrap; gap: 1.25rem 2rem;
    margin-top: 2.5rem; padding-top: 1.75rem;
    border-top: 1px solid color-mix(in oklab, var(--plum) 12%, transparent);
  }
  .hero__trust li { display: grid; gap: 0.1rem; }
  .hero__trust strong {
    font-family: var(--font-display); font-weight: 500; font-size: 1.35rem;
    color: var(--plum); line-height: 1;
  }
  .hero__trust span { font-size: 0.8rem; color: color-mix(in oklab, var(--ink) 65%, transparent); }

  /* Full-bleed photo, feathered into the background */
  .hero__photo { position: relative; z-index: -1; width: 100%; }
  .hero__photo :global(picture) { display: block; width: 100%; height: 100%; }
  .hero__img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: 50% 42%;
    display: block;
  }

  /* Mobile: photo sits below the copy, faded at top + sides into the bg */
  @media (max-width: 859px) {
    .hero__photo { height: 20rem; margin-top: 1rem; }
    .hero__img {
      -webkit-mask-image:
        linear-gradient(to bottom, transparent 0%, #000 22%),
        linear-gradient(to right, transparent 0%, #000 12%, #000 88%, transparent 100%);
      -webkit-mask-composite: source-in;
      mask-image:
        linear-gradient(to bottom, transparent 0%, #000 22%),
        linear-gradient(to right, transparent 0%, #000 12%, #000 88%, transparent 100%);
      mask-composite: intersect;
    }
  }

  /* Desktop: photo covers the right half, fades left into the copy area */
  @media (min-width: 860px) {
    .hero { min-height: clamp(34rem, 82vh, 46rem); justify-content: center; }
    .hero__inner {
      position: relative; z-index: 1;
      padding-block: 4rem;
    }
    .hero__photo {
      position: absolute; top: 0; right: 0; bottom: 0; left: auto;
      width: 60%; height: 100%; margin: 0;
    }
    .hero__img {
      -webkit-mask-image:
        linear-gradient(to right, transparent 0%, #000 44%),
        linear-gradient(to bottom, transparent 0%, #000 14%, #000 86%, transparent 100%);
      -webkit-mask-composite: source-in;
      mask-image:
        linear-gradient(to right, transparent 0%, #000 44%),
        linear-gradient(to bottom, transparent 0%, #000 14%, #000 86%, transparent 100%);
      mask-composite: intersect;
    }
  }
  @media (min-width: 1140px) {
    .hero__photo { width: 56%; }
  }
</style>
