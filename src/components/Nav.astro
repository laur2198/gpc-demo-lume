---
import Logo from './Logo.astro';
---
<header class="nav">
  <a href="#" class="nav__brand"><Logo class="nav__logo" /></a>
  <nav class="nav__links" aria-label="Navigare principală">
    <a href="#servicii">Servicii</a>
    <a href="#galerie">Galerie</a>
    <a href="#pachete">Pachete</a>
    <a href="#contact" class="nav__cta">Rezervă</a>
  </nav>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1.25rem;
    background: color-mix(in oklab, var(--cream) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid color-mix(in oklab, var(--plum) 8%, transparent);
  }
  .nav__brand { text-decoration: none; }
  .nav__logo { font-size: 1.5rem; }
  .nav__links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-size: 0.9375rem;
  }
  .nav__links a {
    color: var(--ink);
    text-decoration: none;
    transition: color .2s ease;
  }
  .nav__links a:hover { color: var(--plum); }
  /* hide section links on small screens, keep the CTA */
  .nav__links a:not(.nav__cta) { display: none; }
  .nav__cta {
    background: var(--plum);
    color: var(--cream) !important;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-weight: 500;
  }
  .nav__cta:hover { background: color-mix(in oklab, var(--plum) 88%, black); }

  @media (min-width: 768px) {
    .nav { padding: 1rem 2rem; }
    .nav__links a:not(.nav__cta) { display: inline; }
  }
</style>
