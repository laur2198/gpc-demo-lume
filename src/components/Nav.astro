---
import Logo from './Logo.astro';

const links = [
  { href: '/servicii/', label: 'Servicii' },
  { href: '/preturi/', label: 'Prețuri' },
  { href: '/#galerie', label: 'Galerie' },
  { href: '/blog/', label: 'Blog' },
];
const cta = { href: '/contact/', label: 'Contact' };
---
<header class="nav">
  <a href="/" class="nav__brand" aria-label="LUMÉ Studio — acasă"><Logo class="nav__logo" /></a>

  <!-- Desktop links -->
  <nav class="nav__links" aria-label="Navigare principală">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
    <a href={cta.href} class="nav__cta">{cta.label}</a>
  </nav>

  <!-- Mobile menu — no JS, native <details> disclosure -->
  <details class="nav__mobile">
    <summary aria-label="Deschide meniul">
      <span class="nav__burger" aria-hidden="true"></span>
    </summary>
    <nav class="nav__panel" aria-label="Navigare">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href={cta.href} class="nav__cta">{cta.label}</a>
    </nav>
  </details>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1.25rem;
    background: color-mix(in oklab, var(--cream) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid color-mix(in oklab, var(--plum) 8%, transparent);
  }
  .nav__brand { text-decoration: none; }
  .nav__logo { font-size: 1.5rem; }

  .nav__links { display: none; align-items: center; gap: 1.25rem; font-size: 0.9375rem; }
  .nav__links a, .nav__panel a {
    color: var(--ink); text-decoration: none; transition: color .2s ease;
  }
  .nav__links a:hover, .nav__panel a:hover { color: var(--plum); }

  .nav__cta {
    background: var(--plum); color: var(--cream) !important;
    padding: 0.5rem 1rem; border-radius: 999px; font-weight: 500;
  }
  .nav__cta:hover { background: color-mix(in oklab, var(--plum) 88%, black); }

  /* Mobile disclosure */
  .nav__mobile { position: relative; }
  .nav__mobile summary {
    list-style: none; cursor: pointer; width: 2.5rem; height: 2.5rem;
    display: grid; place-items: center; border-radius: 0.6rem;
  }
  .nav__mobile summary::-webkit-details-marker { display: none; }
  .nav__burger, .nav__burger::before, .nav__burger::after {
    content: ""; display: block; width: 1.25rem; height: 2px;
    background: var(--plum); border-radius: 2px; position: relative;
    transition: transform .2s ease, opacity .2s ease;
  }
  .nav__burger::before { position: absolute; top: -6px; }
  .nav__burger::after { position: absolute; top: 6px; }
  .nav__mobile[open] .nav__burger { background: transparent; }
  .nav__mobile[open] .nav__burger::before { transform: translateY(6px) rotate(45deg); }
  .nav__mobile[open] .nav__burger::after { transform: translateY(-6px) rotate(-45deg); }

  .nav__panel {
    position: absolute; right: 0; top: calc(100% + 0.6rem);
    display: flex; flex-direction: column; gap: 0.25rem;
    min-width: 12rem; padding: 0.6rem;
    background: var(--cream);
    border: 1px solid color-mix(in oklab, var(--plum) 12%, transparent);
    border-radius: 0.9rem;
    box-shadow: 0 18px 40px -20px color-mix(in oklab, var(--plum) 60%, transparent);
  }
  .nav__panel a { padding: 0.6rem 0.75rem; border-radius: 0.5rem; }
  .nav__panel a:hover { background: color-mix(in oklab, var(--blush) 35%, transparent); }
  .nav__panel .nav__cta { text-align: center; margin-top: 0.25rem; }

  @media (min-width: 768px) {
    .nav { padding: 1rem 2rem; }
    .nav__links { display: flex; }
    .nav__mobile { display: none; }
  }
</style>
