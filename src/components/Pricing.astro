---
const plans = [
  {
    name: 'Esențial',
    price: '180 lei',
    detail: 'extensii classic / stilizare sprâncene',
    note: 'Ideal pentru prima vizită.',
    featured: false,
  },
  {
    name: 'Signature',
    price: '320 lei',
    detail: 'extensii hybrid + laminare sprâncene',
    note: 'Cel mai ales',
    featured: true,
  },
  {
    name: 'Lux',
    price: '480 lei',
    detail: 'volume + tratament ten complet',
    note: 'Experiența completă LUMÉ.',
    featured: false,
  },
];
---
<section id="pachete" class="section pricing">
  <div class="section__inner">
    <header class="section__head section__head--center" data-reveal>
      <p class="section__eyebrow">Pachete</p>
      <h2 class="h2">Alege ritualul potrivit pentru tine.</h2>
    </header>

    <div class="pricing__grid">
      {plans.map((p, i) => (
        <article class:list={["plan", p.featured && "plan--featured"]} data-reveal data-reveal-delay={i + 1}>
          {p.featured && <span class="plan__badge">{p.note}</span>}
          <h3 class="plan__name">{p.name}</h3>
          <p class="plan__price">de la <strong>{p.price}</strong></p>
          <p class="plan__detail">{p.detail}</p>
          {!p.featured && <p class="plan__note">„{p.note}"</p>}
          <a href="#contact" class="plan__cta">Rezervă</a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section { padding: 4rem 1.25rem; }
  .section__inner { max-width: 72rem; margin: 0 auto; }
  .section__head { margin-bottom: 2.5rem; max-width: 36rem; }
  .section__head--center { margin-inline: auto; text-align: center; }
  .section__eyebrow {
    font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--gold); font-weight: 600; margin-bottom: 0.75rem;
  }
  .section__head .h2 { color: var(--plum); }

  .pricing__grid { display: grid; gap: 1.5rem; }
  .plan {
    position: relative;
    background: color-mix(in oklab, var(--cream) 92%, white);
    border: 1px solid color-mix(in oklab, var(--plum) 10%, transparent);
    border-radius: 1.25rem;
    padding: 2rem 1.6rem;
    display: flex;
    flex-direction: column;
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .plan:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -24px color-mix(in oklab, var(--plum) 60%, transparent);
  }
  .plan--featured {
    border-color: var(--gold);
    background: color-mix(in oklab, var(--blush) 30%, var(--cream));
    box-shadow: 0 18px 50px -28px color-mix(in oklab, var(--plum) 70%, transparent);
  }
  .plan__badge {
    position: absolute;
    top: -0.8rem; left: 50%; transform: translateX(-50%);
    background: var(--gold); color: var(--plum);
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.3rem 0.85rem; border-radius: 999px;
    white-space: nowrap;
  }
  .plan__name { color: var(--plum); font-size: 1.5rem; }
  .plan__price { margin-top: 0.6rem; font-size: 1.05rem; color: color-mix(in oklab, var(--ink) 80%, transparent); }
  .plan__price strong { font-family: var(--font-display); font-size: 1.6rem; color: var(--plum); }
  .plan__detail { margin-top: 0.75rem; line-height: 1.6; }
  .plan__note { margin-top: 0.5rem; font-style: italic; color: color-mix(in oklab, var(--ink) 65%, transparent); }
  .plan__cta {
    margin-top: auto;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0.7rem 1.25rem; border-radius: 999px;
    background: var(--plum); color: var(--cream);
    text-decoration: none; font-weight: 500;
    transition: transform .2s ease, background .2s ease;
  }
  .plan__cta:hover { transform: translateY(-2px); background: color-mix(in oklab, var(--plum) 90%, black); }

  @media (min-width: 768px) {
    .section { padding: 5.5rem 2rem; }
    .pricing__grid { grid-template-columns: repeat(3, 1fr); align-items: start; }
  }
</style>
