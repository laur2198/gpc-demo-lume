---
import Img from '../Img.astro';

const SHOTS = [
  { img: 'hero', tag: 'Classic', cls: 'a' },
  { img: 'brow', tag: 'Laminare', cls: 'b' },
  { img: 'skin', tag: 'Glow facial', cls: 'c' },
  { img: 'lash', tag: 'Volume', cls: 'd' },
];
---
<section id="rezultate" class="lume-rezultate">
  <div class="container">
    <div class="lume-rez-head" data-reveal>
      <span class="eyebrow">Rezultate reale</span>
      <h2 class="h2">Lucru fin, <em>vizibil</em> de aproape.</h2>
    </div>
    <div class="lume-rez">
      {SHOTS.map((s) => (
        <figure class:list={['lume-rez-fig', `rez-${s.cls}`]} data-reveal>
          <Img name={s.img} alt="" sizes="(min-width: 820px) 40vw, 50vw" widths={[320, 480, 720]} ratio="4 / 3" />
          <figcaption>{s.tag}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .lume-rezultate { background: var(--surface-alt); padding-block: var(--section-y); }
  .lume-rez-head { margin-bottom: var(--space-12); max-width: 44ch; }
  .lume-rez-head .h2 { margin-top: var(--space-4); }

  .lume-rez {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 150px;
    gap: var(--space-4);
  }
  .lume-rez-fig {
    margin: 0;
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .lume-rez-fig :global(picture) { display: block; width: 100%; height: 100%; }
  .lume-rez-fig :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .lume-rez-fig:hover :global(img) { transform: scale(1.04); }
  .lume-rez-fig figcaption {
    position: absolute;
    left: 0.9rem;
    bottom: 0.9rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cream);
    background: color-mix(in oklab, var(--plum) 70%, transparent);
    backdrop-filter: blur(4px);
    padding: 0.35rem 0.7rem;
    border-radius: var(--radius-pill);
  }
  .rez-a { grid-column: span 4; grid-row: span 2; }
  .rez-b { grid-column: span 2; grid-row: span 1; }
  .rez-c { grid-column: span 2; grid-row: span 1; }
  .rez-d { grid-column: span 6; grid-row: span 1; }

  @media (max-width: 820px) {
    .lume-rez { grid-template-columns: 1fr 1fr; grid-auto-rows: 140px; }
    .rez-a { grid-column: span 2; grid-row: span 2; }
    .rez-b, .rez-c { grid-column: span 1; }
    .rez-d { grid-column: span 2; }
  }
</style>
