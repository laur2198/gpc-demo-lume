---
import Icon from './Icon.astro';

const SERVICES = ['Extensii de gene', 'Sprâncene', 'Îngrijire ten'];
const SLOTS = ['Azi · 14:00', 'Mâine · 11:00', 'Mâine · 16:30', 'Sâm · 10:00'];
---
<div id="lume-booking" class="lume-modal" hidden>
  <div class="lume-modal-sheet" role="dialog" aria-modal="true" aria-label="Rezervă o programare">
    <button type="button" class="lume-modal-x" data-close aria-label="Închide"><Icon name="x" size={18} /></button>

    <form class="lume-modal-form">
      <div>
        <span class="lume-modal-badge">Programare rapidă</span>
        <h3 class="h3 lume-modal-title">Rezervă o programare</h3>
      </div>

      <div>
        <span class="lume-modal-label">Serviciu</span>
        <div class="lume-modal-services">
          {SERVICES.map((s, i) => (
            <button type="button" class:list={['lume-svc-opt', i === 0 && 'is-on']} data-service={s}>{s}</button>
          ))}
        </div>
      </div>

      <div>
        <label class="lume-modal-label" for="lume-name">Nume</label>
        <input id="lume-name" class="lume-modal-field" placeholder="Numele tău" required />
      </div>

      <div>
        <span class="lume-modal-label">Interval disponibil</span>
        <div class="lume-modal-slots">
          {SLOTS.map((s) => (
            <button type="button" class="lume-slot-opt" data-slot={s}>{s}</button>
          ))}
        </div>
      </div>

      <button type="submit" class="btn btn--primary btn--lg lume-modal-submit">Trimite cererea</button>
      <p class="lume-modal-note">Proiect concept — formularul nu trimite date reale.</p>
    </form>

    <div class="lume-modal-done" hidden>
      <span class="lume-modal-check"><Icon name="check" size={26} /></span>
      <h3 class="h3">Cererea ta a fost trimisă</h3>
      <p class="lume-modal-done-text">Te contactăm pe WhatsApp ca să confirmăm <strong data-done-service></strong><span data-done-slot></span>.</p>
      <button type="button" class="btn btn--primary lume-modal-ok" data-close>Înțeles</button>
    </div>
  </div>
</div>

<style>
  .lume-modal {
    position: fixed;
    inset: 0;
    z-index: 80;
    background: color-mix(in oklab, var(--ink) 45%, transparent);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-5);
    animation: lume-fade 0.2s ease;
  }
  .lume-modal[hidden] { display: none; }
  .lume-modal-sheet {
    width: min(460px, 100%);
    background: var(--surface-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    padding: var(--space-10);
    position: relative;
  }
  .lume-modal-x {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-pill);
    border: none;
    background: var(--blush-50);
    color: var(--plum);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .lume-modal-form { display: flex; flex-direction: column; gap: var(--space-5); }
  .lume-modal-badge {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.4em 0.85em;
    border-radius: var(--radius-pill);
    line-height: 1;
    background: var(--blush);
    color: var(--plum);
  }
  .lume-modal-title { margin: var(--space-3) 0 0; }
  .lume-modal-label { font-size: var(--text-sm); font-weight: 600; color: var(--text-heading); margin-bottom: 0.4rem; display: block; }

  .lume-modal-services { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .lume-svc-opt {
    cursor: pointer;
    padding: 0.55rem 1rem;
    border-radius: var(--radius-pill);
    font-size: var(--text-sm);
    font-weight: 500;
    border: 1px solid var(--border-strong);
    background: transparent;
    color: var(--text-body);
  }
  .lume-svc-opt.is-on { border-color: var(--plum); background: var(--plum); color: var(--cream); }

  .lume-modal-field {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-strong);
    background: var(--cream);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: var(--text-base);
  }

  .lume-modal-slots { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
  .lume-slot-opt {
    cursor: pointer;
    padding: 0.6rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    border: 1px solid var(--border-soft);
    background: var(--cream);
    color: var(--text-body);
  }
  .lume-slot-opt.is-on { border-color: var(--gold); background: var(--gold-soft); }

  .lume-modal-submit { width: 100%; }
  .lume-modal-note { margin: 0; text-align: center; font-size: var(--text-xs); color: var(--text-muted); }

  .lume-modal-done {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    text-align: center;
    align-items: center;
    padding-block: var(--space-4);
  }
  .lume-modal-done[hidden] { display: none; }
  .lume-modal-check {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-pill);
    background: var(--gold);
    color: var(--plum);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .lume-modal-done-text { margin: 0; color: var(--text-muted); line-height: var(--leading-body); }
  .lume-modal-done-text strong { color: var(--plum); }
  .lume-modal-ok { margin-top: var(--space-2); }

  @keyframes lume-fade { from { opacity: 0; } to { opacity: 1; } }
</style>

<script>
  function initBooking() {
    const modal = document.getElementById('lume-booking');
    if (!modal || modal.dataset.bound === '1') return;
    modal.dataset.bound = '1';

    const sheet = modal.querySelector('.lume-modal-sheet');
    const form = modal.querySelector('.lume-modal-form');
    const done = modal.querySelector('.lume-modal-done');
    const nameInput = modal.querySelector('#lume-name');
    const svcOpts = Array.from(modal.querySelectorAll('.lume-svc-opt'));
    const slotOpts = Array.from(modal.querySelectorAll('.lume-slot-opt'));
    const doneService = modal.querySelector('[data-done-service]');
    const doneSlot = modal.querySelector('[data-done-slot]');

    let service = svcOpts[0]?.dataset.service || '';
    let slot = '';

    const open = () => {
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      modal.hidden = true;
      document.body.style.overflow = '';
      // reset after the close transition
      setTimeout(() => {
        form.hidden = false;
        done.hidden = true;
        nameInput.value = '';
        slot = '';
        slotOpts.forEach((b) => b.classList.remove('is-on'));
      }, 250);
    };

    document.addEventListener('click', (e) => {
      const t = e.target.closest('[data-book]');
      if (t) { e.preventDefault(); open(); }
    });
    modal.addEventListener('click', (e) => {
      if (e.target === modal || e.target.closest('[data-close]')) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) close();
    });

    svcOpts.forEach((b) => b.addEventListener('click', () => {
      service = b.dataset.service;
      svcOpts.forEach((x) => x.classList.toggle('is-on', x === b));
    }));
    slotOpts.forEach((b) => b.addEventListener('click', () => {
      slot = b.dataset.slot;
      slotOpts.forEach((x) => x.classList.toggle('is-on', x === b));
    }));

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      doneService.textContent = service;
      doneSlot.textContent = slot ? ' · ' + slot : '';
      form.hidden = true;
      done.hidden = false;
    });
  }

  document.addEventListener('astro:page-load', initBooking);
</script>
