---
const PLANS = [
  { name: 'Esențial', price: '180 lei', detail: 'extensii classic / stilizare sprâncene', note: 'Ideal pentru prima vizită.', featured: false },
  { name: 'Signature', price: '320 lei', detail: 'extensii hybrid + laminare sprâncene', note: 'Cel mai ales', featured: true },
  { name: 'Lux', price: '480 lei', detail: 'volume + tratament ten complet', note: 'Experiența completă LUMÉ.', featured: false },
];
---
<section id="pachete" class="lume-pricing">
  <div class="container">
    <div class="lume-pricing-head" data-reveal>
      <span class="eyebrow lume-eyebrow-rule"><span class="rule" aria-hidden="true"></span>Pachete</span>
      <h2 class="h2">Alege experiența potrivită.</h2>
    </div>
    <div class="lume-price-grid">
      {PLANS.map((p) => (
        <div data-reveal>
          <div class:list={['lume-price-card', p.featured && 'is-featured']}>
            <div class="lume-price-top">
              <span class="lume-price-name">{p.name}</span>
              {p.featured && <span class="lume-badge-featured">{p.note}</span>}
            </div>
            <div class="lume-price-amount-row">
              <span class="lume-price-from">de la</span>
              <span class="lume-price-amount">{p.price}</span>
            </div>
            <p class="lume-price-detail">{p.detail}</p>
            {!p.featured && p.note && <p class="lume-price-note">„{p.note}”</p>}
            <div class="lume-price-foot">
              <a href="#contact" class:list={['btn', p.featured ? 'btn--gold' : 'btn--ghost', 'lume-price-btn']}>Rezervă</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .lume-pricing { background: var(--surface-alt); padding-block: var(--section-y); }
  .lume-pricing-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
    align-items: center;
    text-align: center;
    max-width: 44ch;
    margin-inline: auto;
  }
  .lume-eyebrow-rule { display: inline-flex; align-items: center; gap: 0.7em; }
  .lume-eyebrow-rule .rule { width: 2rem; height: 1px; background: var(--gold); display: inline-block; }

  .lume-price-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    align-items: center;
  }
  .lume-price-card {
    background: var(--surface-card);
    color: var(--text-body);
    border-radius: var(--radius-card);
    padding: var(--space-8);
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: relative;
  }
  .lume-price-card.is-featured {
    background: var(--surface-inverse);
    color: var(--text-on-dark);
    box-shadow: var(--shadow-lg);
    transform: translateY(-10px);
  }
  .lume-price-top { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); }
  .lume-price-name { font-family: var(--font-display); font-size: var(--text-h3); color: var(--text-heading); }
  .is-featured .lume-price-name { color: var(--cream); }
  .lume-badge-featured {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.4em 0.85em;
    border-radius: var(--radius-pill);
    line-height: 1;
    background: var(--gold);
    color: var(--plum);
  }
  .lume-price-amount-row { display: flex; align-items: baseline; gap: 0.4em; }
  .lume-price-from { font-size: var(--text-xs); color: var(--text-muted); }
  .is-featured .lume-price-from { color: var(--text-on-dark-muted); }
  .lume-price-amount { font-family: var(--font-display); font-size: var(--text-h1); line-height: 1; color: var(--text-heading); }
  .is-featured .lume-price-amount { color: var(--gold); }
  .lume-price-detail { margin: 0; color: var(--text-muted); line-height: var(--leading-body); }
  .is-featured .lume-price-detail { color: var(--text-on-dark-muted); }
  .lume-price-note { margin: 0; font-style: italic; color: var(--text-muted); }
  .lume-price-foot { margin-top: auto; padding-top: var(--space-4); }
  .lume-price-btn { width: 100%; }

  @media (max-width: 820px) { .lume-price-grid { grid-template-columns: 1fr; } }
</style>
