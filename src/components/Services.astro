---
import Img from './Img.astro';
import { services } from '../data/services';
---
<section id="servicii" class="section services">
  <div class="section__inner">
    <header class="section__head" data-reveal>
      <p class="section__eyebrow">Servicii</p>
      <h2 class="h2">Trei ritualuri, o singură grijă: tu.</h2>
    </header>

    <div class="services__grid">
      {services.map((s, i) => (
        <a class="card service" href={`/servicii/${s.slug}/`} data-reveal data-reveal-delay={i + 1}>
          <Img name={s.img} ratio="4 / 3" alt={s.alt} sizes="(min-width: 768px) 33vw, 100vw" widths={[320, 480, 640]} class="service__img" />
          <div class="service__body">
            <h3 class="service__title">{s.title}</h3>
            <p class="service__tags">{s.tags}</p>
            <p class="service__desc">{s.short}</p>
            <span class="service__more">Vezi detalii →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section { padding: 4rem 1.25rem; }
  .section__inner { max-width: 72rem; margin: 0 auto; }
  .section__head { margin-bottom: 2.5rem; max-width: 36rem; }
  .section__eyebrow {
    font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--gold); font-weight: 600; margin-bottom: 0.75rem;
  }
  .section__head .h2 { color: var(--plum); }

  .services__grid { display: grid; gap: 1.5rem; }
  .card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: color-mix(in oklab, var(--cream) 92%, white);
    border: 1px solid color-mix(in oklab, var(--plum) 8%, transparent);
    border-radius: 1.25rem;
    overflow: hidden;
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .service__more {
    display: inline-block;
    margin-top: 0.9rem;
    color: var(--gold);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -24px color-mix(in oklab, var(--plum) 60%, transparent);
  }
  .service__img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; display: block; border-radius: 0; }
  .service__body { padding: 1.25rem 1.4rem 1.6rem; }
  .service__title { color: var(--plum); font-size: 1.4rem; }
  .service__tags {
    margin-top: 0.35rem; font-size: 0.8125rem; letter-spacing: 0.04em;
    color: var(--gold); font-weight: 600;
  }
  .service__desc { margin-top: 0.75rem; line-height: 1.6; color: color-mix(in oklab, var(--ink) 85%, transparent); }

  @media (min-width: 768px) {
    .section { padding: 5.5rem 2rem; }
    .services__grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
