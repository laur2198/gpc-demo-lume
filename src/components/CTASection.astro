<section id="contact" class="section cta">
  <div class="cta__inner" data-reveal>
    <h2 class="h2 cta__title">Programează-te în câteva secunde.</h2>
    <p class="lead cta__sub">Răspundem rapid pe WhatsApp.</p>

    <div class="cta__actions">
      <a class="cta__wa" href="https://wa.me/40700000000" rel="noopener" target="_blank">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2Zm5.8 14.1c-.2.7-1.4 1.3-2 1.4-.5.1-1.2.1-1.9-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5.1-4.5-.1-.2-1.2-1.6-1.2-3 0-1.4.8-2.1 1-2.4.3-.3.6-.4.8-.4h.6c.2 0 .4 0 .6.5l.9 2.1c.1.2.1.4 0 .6l-.4.6c-.2.2-.4.4-.2.7.2.3.8 1.3 1.7 2.1 1.2 1 2.1 1.4 2.4 1.5.3.1.5.1.7-.1l.8-1c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.3.1.2.1.7-.1 1.4Z"/></svg>
        Scrie-ne pe WhatsApp
      </a>
      <a class="cta__phone" href="tel:0700000000">0700 000 000</a>
    </div>

    <dl class="cta__meta">
      <div>
        <dt>Program</dt>
        <dd>Luni–Sâmbătă · 09:00–19:00</dd>
      </div>
      <div>
        <dt>Adresă</dt>
        <dd>Str. Republicii 12, Brașov</dd>
      </div>
    </dl>
  </div>
</section>

<style>
  .cta {
    padding: 5rem 1.25rem;
    background: color-mix(in oklab, var(--blush) 40%, var(--cream));
    text-align: center;
  }
  .cta__inner { max-width: 40rem; margin: 0 auto; }
  .cta__title { color: var(--plum); }
  .cta__sub { margin-top: 0.75rem; color: color-mix(in oklab, var(--ink) 80%, transparent); }

  .cta__actions {
    margin-top: 2rem;
    display: flex; flex-wrap: wrap; gap: 0.85rem; justify-content: center; align-items: center;
  }
  .cta__wa {
    display: inline-flex; align-items: center; gap: 0.6rem;
    background: #25D366; color: #06351a;
    padding: 0.85rem 1.5rem; border-radius: 999px;
    font-weight: 600; text-decoration: none;
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .cta__wa svg { width: 1.25rem; height: 1.25rem; }
  .cta__wa:hover { transform: translateY(-2px); box-shadow: 0 12px 28px -14px rgba(0,0,0,.35); }
  .cta__phone {
    font-family: var(--font-display);
    font-size: 1.3rem; color: var(--plum); text-decoration: none;
    border-bottom: 2px solid color-mix(in oklab, var(--gold) 60%, transparent);
  }

  .cta__meta {
    margin-top: 2.5rem;
    display: grid; gap: 1.25rem;
    font-size: 0.95rem;
  }
  .cta__meta dt {
    font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--gold); font-weight: 700; margin-bottom: 0.25rem;
  }
  .cta__meta dd { color: var(--ink); }

  @media (min-width: 640px) {
    .cta { padding: 7rem 2rem; }
    .cta__meta { grid-template-columns: repeat(2, 1fr); }
  }
</style>
