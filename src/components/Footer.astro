---
import Logo from './Logo.astro';
---
<footer class="footer">
  <div class="footer__inner">
    <a href="#" class="footer__brand"><Logo class="footer__logo" /></a>
    <nav class="footer__links" aria-label="Navigare subsol">
      <a href="/servicii/">Servicii</a>
      <a href="/preturi/">Prețuri</a>
      <a href="/#galerie">Galerie</a>
      <a href="/blog/">Blog</a>
      <a href="/contact/">Contact</a>
    </nav>
    <p class="footer__copy">© 2026 LUMÉ Studio</p>
    <p class="footer__attrib">Proiect concept realizat de Green Phoenix Concept.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--plum);
    color: color-mix(in oklab, var(--cream) 80%, transparent);
    padding: 3rem 1.25rem 2.5rem;
  }
  .footer__inner {
    max-width: 72rem; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 1.25rem;
    text-align: center;
  }
  .footer__brand .footer__logo { font-size: 1.75rem; color: var(--cream); }
  .footer__links { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.85rem 1.5rem; font-size: 0.95rem; }
  .footer__links a {
    color: color-mix(in oklab, var(--cream) 80%, transparent);
    text-decoration: none; transition: color .2s ease;
  }
  .footer__links a:hover { color: var(--gold); }
  .footer__copy { font-size: 0.9rem; }
  .footer__attrib {
    font-size: 0.78rem;
    color: color-mix(in oklab, var(--cream) 55%, transparent);
    letter-spacing: 0.02em;
  }
</style>
