---
import Base from '../../layouts/Base.astro';
import ConceptBanner from '../../components/lume/ConceptBanner.astro';
import Nav from '../../components/lume/Nav.astro';
import Footer from '../../components/lume/Footer.astro';
import BookingModal from '../../components/lume/BookingModal.astro';
import PageHeader from '../../components/lume/PageHeader.astro';
import CtaBand from '../../components/lume/CtaBand.astro';
import Img from '../../components/Img.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const fmt = (d: Date) => d.toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' });
const CATEGORY: Record<string, string> = { lash: 'Gene', brow: 'Sprâncene', skin: 'Ten' };
---
<Base
  title="Blog — LUMÉ Studio"
  description="Sfaturi despre extensii de gene, sprâncene și îngrijirea tenului de la echipa LUMÉ Studio."
>
  <ConceptBanner />
  <Nav />
  <main>
    <PageHeader
      eyebrow="Blog"
      title="Sfaturi din studio."
      accent="din studio"
      subtitle="Ghiduri scurte despre gene, sprâncene și ten — ca să iei cele mai bune decizii pentru privirea ta."
    />

    <section class="lume-blog">
      <div class="container lume-posts">
        {posts.map((post, i) => (
          <a class="lume-post" href={`/blog/${post.id}/`} data-reveal data-reveal-delay={(i % 3) + 1}>
            <div class="lume-post-img reveal-img">
              <Img name={post.data.cover} ratio="16 / 10" alt={post.data.coverAlt} sizes="(min-width: 768px) 33vw, 100vw" widths={[320, 480, 640]} />
            </div>
            <div class="lume-post-body">
              <span class="eyebrow lume-post-cat">{CATEGORY[post.data.cover] ?? 'Articol'}</span>
              <h2 class="lume-post-title">{post.data.title}</h2>
              <p class="lume-post-desc">{post.data.description}</p>
              <span class="lume-post-meta">{fmt(post.data.date)} · {post.data.readingMinutes} min</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <CtaBand title="Ai o întrebare despre privirea ta?" text="Scrie-ne pe WhatsApp — îți răspundem rapid." />
  </main>
  <Footer />
  <BookingModal />
</Base>

<style>
  .lume-blog { padding-block: clamp(2rem, 5vw, 4rem) var(--section-y); }
  .lume-posts { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-8); }
  .lume-post {
    display: flex; flex-direction: column;
    text-decoration: none; color: inherit;
  }
  .lume-post-img {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    aspect-ratio: 16 / 10;
    margin-bottom: var(--space-5);
  }
  .lume-post-img :global(picture) { display: block; width: 100%; height: 100%; }
  .lume-post-img :global(img) { width: 100%; height: 100%; object-fit: cover; transition: transform var(--dur-base) var(--ease-out); }
  .lume-post:hover .lume-post-img :global(img) { transform: scale(1.04); }
  .lume-post-body { display: flex; flex-direction: column; gap: var(--space-3); }
  .lume-post-cat { color: var(--gold); }
  .lume-post-title { font-family: var(--font-display); font-size: var(--text-h3); color: var(--text-heading); margin: 0; line-height: var(--leading-snug); }
  .lume-post:hover .lume-post-title { color: var(--gold); }
  .lume-post-desc { margin: 0; color: var(--text-muted); line-height: var(--leading-body); }
  .lume-post-meta { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); }

  @media (max-width: 820px) { .lume-posts { grid-template-columns: 1fr; gap: var(--space-10); } }
</style>
