---
import Base from '../../layouts/Base.astro';
import ConceptBanner from '../../components/ConceptBanner.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import BookingBand from '../../components/BookingBand.astro';
import Img from '../../components/Img.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const fmt = (d: Date) => d.toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base
  title="Blog — LUMÉ Studio"
  description="Sfaturi despre extensii de gene, sprâncene și îngrijirea tenului de la echipa LUMÉ Studio."
>
  <ConceptBanner />
  <Nav />
  <main>
    <PageHeader
      eyebrow="Blog"
      title="Sfaturi din studio."
      subtitle="Ghiduri scurte despre gene, sprâncene și ten — ca să iei cele mai bune decizii pentru privirea ta."
    />

    <section class="section">
      <div class="container posts">
        {posts.map((post, i) => (
          <a class="post" href={`/blog/${post.id}/`} data-reveal data-reveal-delay={(i % 3) + 1}>
            <Img name={post.data.cover} ratio="16 / 10" alt={post.data.coverAlt} sizes="(min-width: 768px) 33vw, 100vw" widths={[320, 480, 640]} class="post__img" />
            <div class="post__body">
              <p class="post__meta">{fmt(post.data.date)} · {post.data.readingMinutes} min</p>
              <h2 class="post__title">{post.data.title}</h2>
              <p class="post__desc">{post.data.description}</p>
              <span class="post__more">Citește →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <BookingBand />
  </main>
  <Footer />
</Base>

<style>
  .section { padding-block: 3.5rem 4.5rem; }
  .posts { display: grid; gap: 1.5rem; }
  .post {
    display: block; text-decoration: none; color: inherit;
    background: color-mix(in oklab, var(--cream) 92%, white);
    border: 1px solid color-mix(in oklab, var(--plum) 8%, transparent);
    border-radius: 1.25rem; overflow: hidden;
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .post:hover { transform: translateY(-4px); box-shadow: 0 18px 40px -24px color-mix(in oklab, var(--plum) 60%, transparent); }
  .post__img { width: 100%; aspect-ratio: 16 / 10; object-fit: cover; display: block; }
  .post__body { padding: 1.25rem 1.4rem 1.6rem; }
  .post__meta { font-size: 0.8rem; letter-spacing: 0.04em; color: var(--gold); font-weight: 600; }
  .post__title { margin-top: 0.4rem; color: var(--plum); font-size: 1.3rem; line-height: 1.2; }
  .post__desc { margin-top: 0.6rem; line-height: 1.6; color: color-mix(in oklab, var(--ink) 82%, transparent); }
  .post__more { display: inline-block; margin-top: 0.9rem; color: var(--gold); font-weight: 600; font-size: 0.9rem; }
  @media (min-width: 768px) { .posts { grid-template-columns: repeat(3, 1fr); } }
</style>
