import Filozofie from '../components/lume/Filozofie.astro';
import Services from '../components/lume/Services.astro';
import Procesul from '../components/lume/Procesul.astro';
import Rezultate from '../components/lume/Rezultate.astro';
import Artistul from '../components/lume/Artistul.astro';
import Pricing from '../components/lume/Pricing.astro';
