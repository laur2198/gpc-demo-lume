---
import Base from '../layouts/Base.astro';
import ConceptBanner from '../components/lume/ConceptBanner.astro';
import Nav from '../components/lume/Nav.astro';
import Footer from '../components/lume/Footer.astro';
import BookingModal from '../components/lume/BookingModal.astro';
import PageHeader from '../components/lume/PageHeader.astro';
import CtaBand from '../components/lume/CtaBand.astro';
import { plans } from '../data/pricing';
import { services } from '../data/services';
---
<Base
  title="Prețuri — LUMÉ Studio"
  description="Pachete și tarife pentru extensii de gene, sprâncene și îngrijirea tenului la LUMÉ Studio, Brașov."
>
  <ConceptBanner />
  <Nav />
  <main>
    <PageHeader
      eyebrow="Prețuri"
      title="Tarife clare, fără surprize."
      accent="fără surprize"
      subtitle="Prețurile pornesc de la valorile de mai jos și se confirmă în funcție de serviciul ales și de starea genelor, sprâncenelor sau tenului tău."
    />

    <!-- Packages -->
    <section class="lume-sec">
      <div class="container">
        <div class="lume-sec-head lume-sec-head--center" data-reveal>
          <span class="eyebrow eyebrow--rule">Pachete</span>
          <h2 class="h2">Alege experiența <em>potrivită</em>.</h2>
        </div>
        <div class="lume-price-grid">
          {plans.map((p) => (
            <div data-reveal>
              <div class:list={['lume-price-card', p.featured && 'is-featured']}>
                <div class="lume-price-top">
                  <span class="lume-price-name">{p.name}</span>
                  {p.featured && <span class="lume-badge-featured">{p.note}</span>}
                </div>
                <div class="lume-price-amount-row">
                  <span class="lume-price-from">de la</span>
                  <span class="lume-price-amount">{p.price}</span>
                </div>
                <p class="lume-price-detail">{p.detail}</p>
                {!p.featured && p.note && <p class="lume-price-note">„{p.note}”</p>}
                <div class="lume-price-foot">
                  <button type="button" class:list={['btn', p.featured ? 'btn--gold' : 'btn--ghost', 'lume-price-btn']} data-book>Rezervă</button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Per-service tariffs -->
    <section class="lume-sec lume-sec--alt">
      <div class="container">
        <div class="lume-sec-head" data-reveal>
          <span class="eyebrow eyebrow--rule">Pe serviciu</span>
          <h2 class="h2">Tarife <em>detaliate</em>.</h2>
        </div>
        <div class="lume-tables">
          {services.map((s) => (
            <div class="lume-ptable" data-reveal>
              <div class="lume-ptable-head">
                <h3 class="lume-ptable-title">{s.title}</h3>
                <a class="lume-ptable-link" href={`/servicii/${s.slug}/`}>detalii →</a>
              </div>
              <ul class="lume-prows">
                {s.types.map((t) => (
                  <li class="lume-prow">
                    <span class="lume-prow-name">{t.name}</span>
                    <span class="lume-prow-dur">{t.duration}</span>
                    <span class="lume-prow-price">de la {t.priceFrom} lei</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <p class="lume-note" data-reveal>Tarifele sunt orientative pentru un demo concept. Prețul final se confirmă la programare.</p>
      </div>
    </section>

    <CtaBand title="Nu ești sigură ce ți se potrivește?" text="Scrie-ne și îți recomandăm pachetul potrivit." />
  </main>
  <Footer />
  <BookingModal />
</Base>

<style>
  .lume-sec { padding-block: var(--section-y); }
  .lume-sec--alt { background: var(--surface-alt); }
  .lume-sec-head { margin-bottom: var(--space-10); max-width: 44ch; display: flex; flex-direction: column; gap: var(--space-4); }
  .lume-sec-head--center { align-items: center; text-align: center; margin-inline: auto; margin-bottom: var(--space-12); }

  /* Packages (same language as homepage Pricing) */
  .lume-price-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); align-items: center; }
  .lume-price-card {
    background: var(--surface-card); color: var(--text-body);
    border-radius: var(--radius-card); padding: var(--space-8); box-shadow: var(--shadow-md);
    display: flex; flex-direction: column; gap: var(--space-4); position: relative;
  }
  .lume-price-card.is-featured { background: var(--surface-inverse); color: var(--text-on-dark); box-shadow: var(--shadow-lg); transform: translateY(-10px); }
  .lume-price-top { display: flex; align-items: center; justify-content: space-between; gap: var(--space-3); }
  .lume-price-name { font-family: var(--font-display); font-size: var(--text-h3); color: var(--text-heading); }
  .is-featured .lume-price-name { color: var(--cream); }
  .lume-badge-featured {
    display: inline-flex; align-items: center; gap: 0.4em; font-size: var(--text-xs); font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase; padding: 0.4em 0.85em; border-radius: var(--radius-pill);
    line-height: 1; background: var(--gold); color: var(--plum);
  }
  .lume-price-amount-row { display: flex; align-items: baseline; gap: 0.4em; }
  .lume-price-from { font-size: var(--text-xs); color: var(--text-muted); }
  .is-featured .lume-price-from { color: var(--text-on-dark-muted); }
  .lume-price-amount { font-family: var(--font-display); font-size: var(--text-h1); line-height: 1; color: var(--text-heading); }
  .is-featured .lume-price-amount { color: var(--gold); }
  .lume-price-detail { margin: 0; color: var(--text-muted); line-height: var(--leading-body); }
  .is-featured .lume-price-detail { color: var(--text-on-dark-muted); }
  .lume-price-note { margin: 0; font-style: italic; color: var(--text-muted); }
  .lume-price-foot { margin-top: auto; padding-top: var(--space-4); }
  .lume-price-btn { width: 100%; }

  /* Tariff tables */
  .lume-tables { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .lume-ptable { background: var(--surface-card); border: 1px solid var(--border-soft); border-radius: var(--radius-card); padding: var(--space-6); box-shadow: var(--shadow-sm); }
  .lume-ptable-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-3); gap: var(--space-3); }
  .lume-ptable-title { font-family: var(--font-display); font-size: var(--text-h3); color: var(--text-heading); margin: 0; }
  .lume-ptable-link { font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--gold); text-decoration: none; white-space: nowrap; }
  .lume-ptable-link:hover { text-decoration: underline; }
  .lume-prows { list-style: none; margin: 0; padding: 0; }
  .lume-prow {
    display: grid; grid-template-columns: 1fr auto; gap: 0.15rem 1rem; align-items: baseline;
    padding: 0.8rem 0; border-bottom: 1px solid var(--border-soft);
  }
  .lume-prow:last-child { border-bottom: 0; }
  .lume-prow-name { font-weight: 600; color: var(--text-body); }
  .lume-prow-dur { grid-row: 2; font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); }
  .lume-prow-price { grid-column: 2; grid-row: 1 / span 2; align-self: center; color: var(--gold); font-weight: 600; white-space: nowrap; }
  .lume-note { margin-top: var(--space-6); font-size: var(--text-sm); color: var(--text-muted); }

  @media (max-width: 820px) {
    .lume-price-grid { grid-template-columns: 1fr; }
    .lume-tables { grid-template-columns: 1fr; }
  }
</style>
