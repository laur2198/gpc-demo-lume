---
import Base from '../../layouts/Base.astro';
import ConceptBanner from '../../components/lume/ConceptBanner.astro';
import Nav from '../../components/lume/Nav.astro';
import Footer from '../../components/lume/Footer.astro';
import BookingModal from '../../components/lume/BookingModal.astro';
import CtaBand from '../../components/lume/CtaBand.astro';
import Img from '../../components/Img.astro';
import { services } from '../../data/services';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const others = services.filter((s) => s.slug !== service.slug);

// italic-gold accent word per service title
const ACCENT: Record<string, string> = {
  'extensii-gene': 'gene',
  sprancene: 'Sprâncene',
  'ingrijire-ten': 'ten',
};
const accent = ACCENT[service.slug] ?? '';
let tBefore = service.title, tEm = '', tAfter = '';
if (accent && service.title.includes(accent)) {
  const i = service.title.indexOf(accent);
  tBefore = service.title.slice(0, i);
  tEm = accent;
  tAfter = service.title.slice(i + accent.length);
}
---
<Base title={`${service.title} — LUMÉ Studio`} description={service.short}>
  <ConceptBanner />
  <Nav />
  <main>
    <!-- Short warm-light hero -->
    <section class="lume-shero">
      <div class="container lume-shero-grid">
        <div class="lume-shero-copy" data-reveal>
          <span class="eyebrow eyebrow--rule">Serviciu</span>
          <h1 class="h1 lume-shero-title">{tBefore}{tEm && <em>{tEm}</em>}{tAfter}</h1>
          <p class="lead lume-shero-sub">{service.intro}</p>
          <div class="lume-shero-meta">
            <span class="eyebrow lume-shero-from">de la</span>
            <span class="lume-shero-amount">{service.priceFrom} lei</span>
            <span class="lume-shero-dur">· {service.duration}</span>
          </div>
          <div class="lume-shero-actions">
            <button type="button" class="btn btn--primary btn--lg" data-book>Rezervă o programare</button>
            <a class="btn btn--ghost btn--lg" href="/preturi/">Vezi toate prețurile</a>
          </div>
        </div>
        <div class="lume-shero-media reveal-img" data-reveal data-reveal-delay="1">
          <Img name={service.img} alt={service.alt} ratio="4 / 5" sizes="(min-width: 900px) 42vw, 100vw" widths={[420, 600, 820]} />
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="lume-sec lume-sec--alt">
      <div class="container lume-benefits-grid">
        <div data-reveal>
          <span class="eyebrow eyebrow--rule">De ce LUMÉ</span>
          <h2 class="h2 lume-sec-title">Detaliul pe care îl <em>simți</em>.</h2>
        </div>
        <ul class="lume-benefits" data-reveal data-reveal-delay="1">
          {service.benefits.map((b) => <li>{b}</li>)}
        </ul>
      </div>
    </section>

    <!-- Options & pricing -->
    <section class="lume-sec">
      <div class="container">
        <div class="lume-sec-head" data-reveal>
          <span class="eyebrow eyebrow--rule">Opțiuni & tarife</span>
          <h2 class="h2 lume-sec-title">Alege varianta <em>potrivită</em>.</h2>
        </div>
        <div class="lume-types">
          {service.types.map((t, i) => (
            <div class="lume-type" data-reveal data-reveal-delay={(i % 3) + 1}>
              <div class="lume-type-head">
                <h3 class="lume-type-name">{t.name}</h3>
                <span class="lume-type-price">de la {t.priceFrom} lei</span>
              </div>
              <p class="lume-type-desc">{t.desc}</p>
              <span class="lume-type-dur">{t.duration}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="lume-sec lume-sec--alt">
      <div class="container lume-faqwrap">
        <div class="lume-sec-head" data-reveal>
          <span class="eyebrow eyebrow--rule">Întrebări frecvente</span>
          <h2 class="h2 lume-sec-title">Bine de <em>știut</em>.</h2>
        </div>
        <div class="lume-acc" data-reveal data-reveal-delay="1">
          {service.faq.map((f, i) => (
            <details open={i === 0}>
              <summary>{f.q}<span class="lume-acc-mark" aria-hidden="true">+</span></summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Other services -->
    <section class="lume-sec">
      <div class="container">
        <div class="lume-sec-head" data-reveal>
          <span class="eyebrow eyebrow--rule">Mai departe</span>
          <h2 class="h2 lume-sec-title">Alte <em>ritualuri</em>.</h2>
        </div>
        <div class="lume-others">
          {others.map((s) => (
            <a class="lume-other" href={`/servicii/${s.slug}/`} data-reveal>
              <div class="lume-other-img reveal-img">
                <Img name={s.img} alt={s.alt} ratio="4 / 3" sizes="(min-width: 768px) 45vw, 100vw" widths={[320, 480, 640]} />
              </div>
              <div class="lume-other-body">
                <h3 class="lume-other-title">{s.title}</h3>
                <span class="lume-other-more">Vezi detalii →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CtaBand title="Pregătită pentru programare?" text="Scrie-ne pe WhatsApp sau lasă-ne un mesaj rapid." />
  </main>
  <Footer />
  <BookingModal />
</Base>

<style>
  .lume-sec { padding-block: var(--section-y); }
  .lume-sec--alt { background: var(--surface-alt); }
  .lume-sec-head { margin-bottom: var(--space-10); max-width: 44ch; display: flex; flex-direction: column; gap: var(--space-4); }
  .lume-sec-title { margin: 0; }

  /* Short hero */
  .lume-shero { padding-block: clamp(2.5rem, 6vw, 5rem); }
  .lume-shero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(2rem, 6vw, 5rem); align-items: center; }
  .lume-shero-copy { display: flex; flex-direction: column; gap: var(--space-5); }
  .lume-shero-title { margin: 0; }
  .lume-shero-sub { margin: 0; max-width: 46ch; }
  .lume-shero-meta { display: flex; align-items: baseline; gap: 0.4em; }
  .lume-shero-from { color: var(--text-muted); }
  .lume-shero-amount { font-family: var(--font-display); font-size: var(--text-h2); color: var(--text-heading); line-height: 1; }
  .lume-shero-dur { font-size: var(--text-sm); color: var(--text-muted); }
  .lume-shero-actions { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-2); }
  .lume-shero-media {
    border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow-lg); aspect-ratio: 4 / 5;
  }
  .lume-shero-media :global(picture) { display: block; width: 100%; height: 100%; }
  .lume-shero-media :global(img) { width: 100%; height: 100%; object-fit: cover; }

  /* Benefits */
  .lume-benefits-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
  .lume-benefits { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-4); }
  .lume-benefits li { position: relative; padding-left: 1.9rem; line-height: var(--leading-body); color: var(--text-body); }
  .lume-benefits li::before {
    content: ""; position: absolute; left: 0; top: 0.55em;
    width: 0.6rem; height: 0.6rem; border-radius: 999px; background: var(--gold);
  }

  /* Types */
  .lume-types { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .lume-type {
    background: var(--surface-card);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-card);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
    display: flex; flex-direction: column; gap: var(--space-3);
  }
  .lume-type-head { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-3); }
  .lume-type-name { font-family: var(--font-display); font-size: var(--text-h3); color: var(--text-heading); margin: 0; }
  .lume-type-price { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: 0.06em; text-transform: uppercase; color: var(--gold); white-space: nowrap; }
  .lume-type-desc { margin: 0; color: var(--text-muted); line-height: var(--leading-body); }
  .lume-type-dur { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); }

  /* FAQ accordion (same language as homepage) */
  .lume-faqwrap { max-width: 48rem; }
  .lume-acc { display: flex; flex-direction: column; gap: var(--space-3); }
  .lume-acc details { background: var(--surface-card); border-radius: var(--radius-md); border: 1px solid var(--border-soft); padding: var(--space-5) var(--space-6); }
  .lume-acc summary {
    list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between;
    gap: var(--space-4); font-family: var(--font-display); font-size: var(--text-h3); color: var(--text-heading);
  }
  .lume-acc summary::-webkit-details-marker { display: none; }
  .lume-acc-mark { color: var(--gold); font-size: 1.4em; line-height: 1; flex: none; display: inline-block; transition: transform var(--dur-fast) var(--ease-soft); }
  .lume-acc details[open] .lume-acc-mark { transform: rotate(45deg); }
  .lume-acc p { margin: var(--space-3) 0 0; color: var(--text-muted); line-height: var(--leading-body); }

  /* Other services */
  .lume-others { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-6); }
  .lume-other {
    display: block; text-decoration: none; color: inherit;
    background: var(--surface-card); border-radius: var(--radius-lg); overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur-fast) var(--ease-soft), box-shadow var(--dur-fast) var(--ease-soft);
  }
  .lume-other:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .lume-other-img { aspect-ratio: 4 / 3; overflow: hidden; }
  .lume-other-img :global(picture) { display: block; width: 100%; height: 100%; }
  .lume-other-img :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .lume-other-body { padding: var(--space-5) var(--space-6); display: flex; justify-content: space-between; align-items: center; gap: var(--space-4); }
  .lume-other-title { font-family: var(--font-display); font-size: var(--text-h3); color: var(--text-heading); margin: 0; }
  .lume-other-more { font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em; color: var(--gold); white-space: nowrap; }

  @media (max-width: 900px) {
    .lume-shero-grid { grid-template-columns: 1fr; }
    .lume-shero-media { max-width: 26rem; }
    .lume-benefits-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 820px) {
    .lume-types { grid-template-columns: 1fr; }
    .lume-others { grid-template-columns: 1fr; }
  }
</style>
