---
import Base from '../../layouts/Base.astro';
import ConceptBanner from '../../components/ConceptBanner.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import BookingBand from '../../components/BookingBand.astro';
import Img from '../../components/Img.astro';
import { services } from '../../data/services';
---
<Base
  title="Servicii — LUMÉ Studio"
  description="Extensii de gene, stilizare sprâncene și îngrijirea tenului. Descoperă serviciile LUMÉ Studio din Brașov."
>
  <ConceptBanner />
  <Nav />
  <main>
    <PageHeader
      eyebrow="Servicii"
      title="Ritualuri gândite pentru privirea ta."
      subtitle="Trei direcții, un singur standard: tehnică certificată, produse premium și un spațiu intim, fără grabă."
    />

    <section class="section">
      <div class="container services-grid">
        {services.map((s, i) => (
          <a class="card" href={`/servicii/${s.slug}/`} data-reveal data-reveal-delay={(i % 3) + 1}>
            <Img name={s.img} ratio="4 / 3" alt={s.alt} sizes="(min-width: 768px) 33vw, 100vw" widths={[320, 480, 640]} class="card__img" />
            <div class="card__body">
              <h2 class="card__title">{s.title}</h2>
              <p class="card__tags">{s.tags}</p>
              <p class="card__desc">{s.short}</p>
              <p class="card__price">de la <strong>{s.priceFrom} lei</strong> · {s.duration}</p>
              <span class="card__more">Vezi detalii →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <BookingBand />
  </main>
  <Footer />
</Base>

<style>
  .section { padding-block: 3.5rem 4.5rem; }
  .services-grid { display: grid; gap: 1.5rem; }
  .card {
    display: block; text-decoration: none; color: inherit;
    background: color-mix(in oklab, var(--cream) 92%, white);
    border: 1px solid color-mix(in oklab, var(--plum) 8%, transparent);
    border-radius: 1.25rem; overflow: hidden;
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .card:hover { transform: translateY(-4px); box-shadow: 0 18px 40px -24px color-mix(in oklab, var(--plum) 60%, transparent); }
  .card__img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; display: block; }
  .card__body { padding: 1.25rem 1.4rem 1.6rem; }
  .card__title { color: var(--plum); font-size: 1.4rem; }
  .card__tags { margin-top: 0.35rem; font-size: 0.8125rem; letter-spacing: 0.04em; color: var(--gold); font-weight: 600; }
  .card__desc { margin-top: 0.75rem; line-height: 1.6; color: color-mix(in oklab, var(--ink) 85%, transparent); }
  .card__price { margin-top: 0.75rem; font-size: 0.95rem; }
  .card__price strong { font-family: var(--font-display); color: var(--plum); }
  .card__more { display: inline-block; margin-top: 0.9rem; color: var(--gold); font-weight: 600; font-size: 0.9rem; }
  @media (min-width: 768px) { .services-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
